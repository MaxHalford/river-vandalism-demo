POSTGRES_DSN=postgres://river:river@localhost:5432/river
SSE_RECENTCHANGE=https://stream.wikimedia.org/v2/stream/recentchange
SSE_TAGS=https://stream.wikimedia.org/v2/stream/mediawiki.revision-tags-change
# Single wiki: WIKI_FILTERS=enwiki
# Multilingual: WIKI_FILTERS=enwiki,dewiki,frwiki,eswiki,ptwiki,itwiki,jawiki
WIKI_FILTERS=enwiki
NAMESPACE_FILTER=0
LIFTWING_URL=https://api.wikimedia.org/service/lw/inference/v1/models/revertrisk-language-agnostic:predict
LIFTWING_TIMEOUT_S=4
LIFTWING_SAMPLE_RATE=1.0
SAMPLE_RATE=1.0
DB_BATCH_SIZE=200
DB_BATCH_MAX_S=0.5
LEARNER_BATCH_SIZE=5000
LEARNER_BATCH_INTERVAL_S=5
LABEL_TTL_HOURS=48
BATCH_RETRAIN_INTERVAL_HOURS=24
BATCH_TRAIN_WINDOW_DAYS=7
AUTORESEARCH_ENABLED=false
AUTORESEARCH_INTERVAL_HOURS=24
AUTORESEARCH_BACKTEST_HOURS=48
AUTORESEARCH_PROMOTE_DELTA=0.005
AUTORESEARCH_PROMOTE_PVALUE=0.05
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
DASHBOARD_PORT=8000
LOG_LEVEL=INFO
